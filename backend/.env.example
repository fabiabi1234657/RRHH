# ─── Base de datos ────────────────────────────────────────────────────────────
# URI de conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/rrhh_db

# URI para la base de datos de tests (Jest)
MONGO_URI_TEST=mongodb://localhost:27017/rrhh_test

# ─── Autenticación JWT ────────────────────────────────────────────────────────
# CAMBIAR en producción — usar un string largo y aleatorio (mín. 64 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UN_SECRET_LARGO_Y_ALEATORIO

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL final del frontend desplegado en Render.
# En local no es obligatorio porque el backend ya permite:
# - http://localhost:5173
# - http://localhost:3000
# Ejemplo produccion: https://rrhh-frontend.onrender.com
FRONTEND_URL=

# ─── Seed de datos ────────────────────────────────────────────────────────────
# Contraseña por defecto para datos de prueba (seed)
SEED_PASSWORD=Password123

# Credenciales del admin inicial (usado por: npm run seed:admin)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASS=CambiarEstaContra123!
